{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "mac-timer",
  "version": "1.0.0",
  "title": "Mac Timer",
  "description": "Set timers and alarms in the macOS Clock app",
  "icon": "extension-icon.png",
  "author": "schmas",
  "owner": "shmas-corp",
  "platforms": ["macOS"],
  "categories": ["Productivity"],
  "license": "MIT",
  "commands": [
    {
      "name": "set-timer",
      "title": "Set Timer",
      "description": "Start a timer in the macOS Clock app",
      "mode": "no-view",
      "arguments": [
        {
          "name": "duration",
          "placeholder": "10m, 1.5h, 34s, 5:30",
          "type": "text",
          "required": true
        }
      ]
    },
    {
      "name": "set-alarm",
      "title": "Set Alarm",
      "description": "Create an alarm in the macOS Clock app",
      "mode": "no-view",
      "arguments": [
        {
          "name": "time",
          "placeholder": "7:30 or 19:00",
          "type": "text",
          "required": true
        },
        {
          "name": "label",
          "placeholder": "Optional name",
          "type": "text",
          "required": false
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.17",
    "@raycast/utils": "^2.2.4"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.19.17",
    "@types/react": "19.0.10",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.22.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "publish": "npx @raycast/api@latest publish"
  }
}
